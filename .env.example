# ==============================================================================
# Environment Variables for Copernicus Data Space S3 Access
# ==============================================================================
# 1. Copy this file to '.env'
# 2. Get your credentials from: https://dataspace.copernicus.eu/
#    - Create an account
#    - Go to User Settings > S3 Access
#    - Generate new S3 credentials
# 3. Fill in your actual credentials below
#
# IMPORTANT: Never commit your actual .env file to git!

# Copernicus Data Space S3 Credentials
S3_ACCESS_KEY=your_access_key_here
S3_SECRET_KEY=your_secret_key_here
